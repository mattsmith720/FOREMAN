// Set this to your Mac's LAN IP when testing on a physical iPhone.
BACKEND_API_URL = http:/$()/192.168.0.88:8080
DEVELOPMENT_TEAM =

// Mock device (phone camera as glasses feed). Set to NO for real Meta glasses.
FOREMAN_USE_MOCK_DEVICE = YES

// Mock development placeholders. Real values live in Local.xcconfig (git-ignored),
// included at the end so it overrides anything here.
META_APP_ID = 0
CLIENT_TOKEN =
FOREMAN_API_KEY =

#include? "Local.xcconfig"
