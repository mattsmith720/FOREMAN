# Backend environment variables.
# Copy to backend/.env and fill in. Never commit the real .env.

# Anthropic (Claude analysis call)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
# Lower = faster coaching JSON (default 512).
ANTHROPIC_MAX_TOKENS=512

# OpenAI (Whisper speech-to-text for audio transcription)
OPENAI_API_KEY=

# ElevenLabs (Australian male TTS + optional live ConvAI coach)
# Voice: Charlie (AU male) by default — override with ELEVENLABS_VOICE_ID
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=IKne3meq5aSn9XLyUdCD
# Optional: ElevenLabs ConvAI agent for live two-way voice (dashboard → agent id)
ELEVENLABS_AGENT_ID=

# Supabase (Postgres + storage) — project uvlgbsiwyvtsjlqzozas
# Schema + frames bucket: already applied (see backend/supabase/schema.sql).
# Keys: https://supabase.com/dashboard/project/uvlgbsiwyvtsjlqzozas/settings/api
SUPABASE_URL=https://uvlgbsiwyvtsjlqzozas.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Required in production. Same value on Vercel (server-only, not NEXT_PUBLIC_*).
FOREMAN_API_KEY=

# Optional separate secret for session HMAC tokens (defaults to FOREMAN_API_KEY).
SESSION_TOKEN_SECRET=

# Optional password gate for the internal /ops dashboard, in addition to the
# FOREMAN_API_KEY the Vercel proxy injects. If unset, /ops relies on the API key.
OPS_PASSWORD=

# Comma-separated browser origins allowed to call the API directly.
# Default: allow all. Production example:
# CORS_ORIGINS=https://foreman-phi.vercel.app
CORS_ORIGINS=

# Site video ingest (tradie uploads → training data)
# Secret for Google Drive Apps Script + cron hitting /ingest/process-pending
INGEST_WEBHOOK_SECRET=
# Extract one frame every N seconds (default 10), max 60 frames per video
INGEST_FRAME_INTERVAL_SEC=10
INGEST_MAX_FRAMES=60
# true = Claude labels on each extracted frame (costly; default off)
INGEST_ANALYSE_FRAMES=false

# Persist raw audio chunks to the private audio bucket + audio_segments table on
# every /transcribe (requires training-iteration-a.sql). Off by default.
AUDIO_PERSIST=false

# Server
PORT=8080

# Use the legacy JWT service_role key (starts with eyJ...) for SUPABASE_SERVICE_ROLE_KEY.
# Do NOT use sb_secret_* here — the backend expects the JWT format.

# Cloudflare (DNS setup scripts only — copy real values to backend/.env, never commit tokens)
# Create token: https://dash.cloudflare.com/profile/api-tokens → Edit zone DNS for unicityai.com.au
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_ZONE=unicityai.com.au