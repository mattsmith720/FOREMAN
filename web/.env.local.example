# Web client environment. Copy to web/.env.local

# --- Local same-Wi-Fi testing (npm run dev:phone) ---
NEXT_PUBLIC_API_URL=same-origin
BACKEND_URL=http://127.0.0.1:8080

# --- Vercel production (set in Vercel dashboard, not in .env.local) ---
# Phone camera frames exceed Vercel's 4.5 MB proxy limit — call Render directly:
# NEXT_PUBLIC_API_URL=https://foreman-api-y31r.onrender.com
# NEXT_PUBLIC_FOREMAN_API_KEY=same-value-as-FOREMAN_API_KEY-on-Render
# BACKEND_URL=https://foreman-api-y31r.onrender.com
# FOREMAN_API_KEY=same-value-as-above
# CORS_ORIGINS on Render must include https://foreman-phi.vercel.app
